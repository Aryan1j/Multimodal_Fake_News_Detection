# Fake News Classifier Environment Configuration
# Copy this file to .env and fill in your values

# Optional: Enable external news API evidence checks
# Set to "true" to enable, "false" or omit to disable
ENABLE_NEWS_EVIDENCE=false

# Optional: News API keys for evidence checking
# Get your key from https://newsapi.org/
NEWS_API_KEY=

# Get your key from https://gnews.io/
GNEWS_API_KEY=

# Optional: Disable SSL certificate patching (for macOS HuggingFace downloads)
# Set to "1" to skip certifi SSL patching
PROJECT_DISABLE_CERTIFI_SSL=
